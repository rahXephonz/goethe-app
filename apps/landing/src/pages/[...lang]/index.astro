---
import { createTranslator, resolveLocale } from "@goethepro/i18n";
import { ArrowUpRight } from "@lucide/astro";
import HeroStars from "../../components/hero-stars.astro";
import LandingLayout from "../../layouts/landing-layout.astro";
import { appUrl } from "../../lib/app-url";

// Static locale routes: / (en), /id/, /de/. Navbar + chrome are translated;
// body copy is placeholder-English until the content/design pass.
export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "id" } }, { params: { lang: "de" } }];
}

const locale = resolveLocale(Astro.params.lang);
const t = createTranslator(locale);
---

<LandingLayout locale={locale} title="goethe.pro — German for the Ausbildung route">
  <main>
    <section
      class="relative flex min-h-svh flex-col items-center justify-center overflow-hidden px-6 text-center"
    >
      <img
        src="/images/hero-night.webp"
        srcset="/images/hero-night-sm.webp 960w, /images/hero-night.webp 1440w, /images/hero-night-2x.webp 2880w"
        sizes="100vw"
        width="1440"
        height="1024"
        alt=""
        fetchpriority="high"
        class="absolute inset-0 -z-10 size-full object-cover"
      />
      <HeroStars />
      <div class="flex max-w-3xl flex-col items-center gap-6 pt-14">
        <h1
          data-reveal
          class="font-display text-6xl font-normal tracking-tight text-white sm:text-7xl"
        >
          {t("landing.hero.title")}
        </h1>
        <p data-reveal class="max-w-xl text-lg text-white/85">
          {t("landing.hero.subtitle")}
        </p>
        <div data-reveal class="flex items-center gap-2">
          <a
            href={appUrl("/register")}
            class="rounded-full bg-linear-to-b from-brand to-brand-deep px-7 py-3.5 font-semibold text-white shadow-sm transition hover:-translate-y-px hover:shadow-md hover:brightness-110"
          >
            {t("landing.hero.redeemInvite")}
          </a>
          <a
            href={appUrl("/login")}
            aria-label={t("auth.login.title")}
            class="grid size-13 place-items-center rounded-full bg-linear-to-b from-brand to-brand-deep text-white shadow-sm transition hover:-translate-y-px hover:shadow-md hover:brightness-110"
          >
            <ArrowUpRight size={16} aria-hidden="true" />
          </a>
        </div>
      </div>
    </section>

    <section id="how-it-works" class="mx-auto max-w-5xl px-6 py-24">
      <h2 data-reveal class="font-display text-6xl font-normal tracking-tight">
        One honest daily loop
      </h2>
      <div data-reveal-group class="mt-12 grid gap-8 sm:grid-cols-3">
        <div
          data-reveal
          class="rounded-2xl border border-ink/10 bg-white p-6 transition-colors hover:border-brand"
        >
          <h3 class="font-semibold">Today's Plan</h3>
          <p class="mt-2 text-sm text-ink/60">
            One unit, your due reviews, one exam. No infinite feed.
          </p>
        </div>
        <div
          data-reveal
          class="rounded-2xl border border-ink/10 bg-white p-6 transition-colors hover:border-brand"
        >
          <h3 class="font-semibold">Daily Exam</h3>
          <p class="mt-2 text-sm text-ink/60">
            Ten questions assembled only from vocab and grammar you have met.
          </p>
        </div>
        <div
          data-reveal
          class="rounded-2xl border border-ink/10 bg-white p-6 transition-colors hover:border-brand"
        >
          <h3 class="font-semibold">Real progress</h3>
          <p class="mt-2 text-sm text-ink/60">
            Skill scores appear once there is enough data — never before.
          </p>
        </div>
      </div>
    </section>

    <section class="flex flex-col items-center gap-6 px-6 py-32 text-center">
      <h2 data-reveal class="font-display text-4xl font-normal tracking-tight">
        Have an invite code?
      </h2>
      <a
        data-reveal
        href={appUrl("/register")}
        class="rounded-xl bg-linear-to-b from-brand to-brand-deep px-6 py-3 font-semibold text-white shadow-sm transition hover:-translate-y-px hover:shadow-md hover:brightness-110"
      >
        Create your account
      </a>
    </section>
  </main>
</LandingLayout>
