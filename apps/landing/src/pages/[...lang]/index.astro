---
import { createTranslator, resolveLocale } from "@lingua/i18n";
import { ArrowUpRight } from "@lucide/astro";
import EarlyAccess from "../../components/early-access.astro";
import Faq from "../../components/faq.astro";
import HeroStars from "../../components/hero-stars.astro";
import LearningPath from "../../components/learning-path.astro";
import Philosophy from "../../components/philosophy.astro";
import LandingLayout from "../../layouts/landing-layout.astro";
import { appUrl } from "../../lib/app-url";

// Static locale routes: / (en), /id/, /de/. Navbar + chrome are translated;
// body copy is placeholder-English until the content/design pass.
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "id" } },
    { params: { lang: "de" } },
    { params: { lang: "ja" } },
  ];
}

const locale = resolveLocale(Astro.params.lang);
const t = createTranslator(locale);
---

<LandingLayout locale={locale} title="linguaa.app — languages in the quiet hours">
  <main>
    <section
      class="sticky top-0 z-0 flex min-h-svh flex-col items-center justify-center overflow-hidden px-6 text-center"
    >
      <img
        src="/images/hero-night.webp"
        srcset="/images/hero-night-sm.webp 960w, /images/hero-night.webp 1440w, /images/hero-night-2x.webp 2880w"
        sizes="100vw"
        width="1440"
        height="1024"
        alt=""
        fetchpriority="high"
        class="absolute inset-0 -z-10 size-full object-cover"
      />
      <HeroStars />
      <div data-hero-inner class="flex max-w-3xl flex-col items-center gap-6 pt-14">
        <h1
          data-reveal
          class="font-display text-6xl font-normal tracking-tight text-white sm:text-7xl"
        >
          {t("landing.hero.title")}
        </h1>
        <p data-reveal class="max-w-xl text-lg text-white/85">
          {t("landing.hero.subtitle")}
        </p>
        <div data-reveal class="flex items-center gap-2">
          <a
            href="#early-access"
            class="rounded-full bg-linear-to-b from-brand to-brand-deep px-7 py-3.5 font-semibold text-white shadow-sm transition hover:-translate-y-px hover:shadow-md hover:brightness-110"
          >
            {t("landing.hero.joinWaitlist")}
          </a>
          <a
            href={appUrl("/login")}
            aria-label={t("auth.login.title")}
            class="grid size-13 place-items-center rounded-full bg-linear-to-b from-brand to-brand-deep text-white shadow-sm transition hover:-translate-y-px hover:shadow-md hover:brightness-110"
          >
            <ArrowUpRight size={16} aria-hidden="true" />
          </a>
        </div>
      </div>
    </section>

    <div
      data-hero-overlay
      class="relative z-10 overflow-hidden rounded-t-3xl bg-cream shadow-[0_-24px_60px_rgba(10,16,28,0.35)]"
    >
      <LearningPath locale={locale} />
      <Philosophy locale={locale} />
      <Faq locale={locale} />
      <EarlyAccess locale={locale} />
    </div>
  </main>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    // As the overlay rises, the pinned hero content recedes slightly —
    // scale + fade scrubbed to scroll, like a sheet covering a screen.
    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      gsap.registerPlugin(ScrollTrigger);
      gsap.to("[data-hero-inner]", {
        scale: 0.92,
        autoAlpha: 0.35,
        ease: "none",
        scrollTrigger: {
          trigger: "[data-hero-overlay]",
          start: "top bottom",
          end: "top 25%",
          scrub: true,
        },
      });
    }
  </script>
</LandingLayout>
