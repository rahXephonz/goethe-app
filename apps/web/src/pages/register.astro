---
import { createTranslator } from "@goethepro/i18n";
import Layout from "../layouts/layout.astro";
import { RegisterFormIsland } from "../components/register-form";

const { locale } = Astro.locals;
const t = createTranslator(locale);
---

<Layout title={`${t("auth.register.title")} — ${t("common.appName")}`}>
  <main class="mx-auto mt-[12vh] w-full max-w-sm px-4">
    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <h1 class="mb-6 text-xl font-semibold">{t("auth.register.title")}</h1>
      <RegisterFormIsland client:load locale={locale} />
      <p class="mt-4 text-sm text-gray-600">
        {t("auth.register.haveAccount")}
        <a href="/login" class="font-medium text-gray-900 underline"
          >{t("auth.register.loginLink")}</a
        >
      </p>
    </div>
  </main>
</Layout>
