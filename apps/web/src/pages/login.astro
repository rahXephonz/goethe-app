---
// Public page; middleware redirects authenticated users away.
import { createTranslator } from "@goethepro/i18n";
import Layout from "../layouts/layout.astro";
import { LoginFormIsland } from "../components/login-form";

const { locale } = Astro.locals;
const t = createTranslator(locale);
---

<Layout title={`${t("auth.login.title")} — ${t("common.appName")}`}>
  <main class="mx-auto mt-[12vh] w-full max-w-sm px-4">
    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <h1 class="mb-6 text-xl font-semibold">{t("auth.login.title")}</h1>
      <LoginFormIsland client:load locale={locale} />
      <p class="mt-4 text-sm text-gray-600">
        {t("auth.login.noAccount")}
        <a href="/register" class="font-medium text-gray-900 underline"
          >{t("auth.login.registerLink")}</a
        >
      </p>
    </div>
  </main>
</Layout>
